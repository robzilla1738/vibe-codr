# vibe-codr provider credentials
# Copy to .env (gitignored) and fill in the keys you use.
# Only the providers you set keys for become "configured" and queryable.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
FIREWORKS_API_KEY=
BASETEN_API_KEY=

# xAI / Grok — key from console.x.ai. Point XAI_BASE_URL at a gateway if your
# Grok subscription is brokered elsewhere.
XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1

# MiniMax — OpenAI-compatible; your subscription token. MINIMAX_BASE_URL for region.
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# OpenAI Codex — reuses ~/.codex/auth.json by default (run `codex login`).
# An API key works directly; for ChatGPT-subscription OAuth set CODEX_BASE_URL
# (and providers.codex.headers in config) to your Codex backend.
# CODEX_API_KEY=
# CODEX_BASE_URL=

# LM Studio runs locally with no key. Override the base URL if not default.
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Ollama. Local (`ollama serve`) is keyless: ollama/<name>, e.g. ollama/llama3.1.
# Ollama Cloud: set OLLAMA_API_KEY (ollama.com/settings/keys) and it auto-targets
# https://ollama.com/v1 — ids are plain, e.g. ollama/gpt-oss:120b (run `vibecodr
# models` to list yours). Override the host with OLLAMA_BASE_URL.
# OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1

# Web search works KEYLESS by default (DuckDuckGo). A TinyFish key (free tier, no
# card — agent.tinyfish.ai) is an OPTIONAL higher-quality booster tried first.
TINYFISH_API_KEY=

# Long-term memory is offline by default (lexical BM25 recall). For SEMANTIC
# recall, either install the optional on-device embedder
# (`bun add @huggingface/transformers`, then memory.semantic.model = "local"),
# or set memory.semantic.model to a cloud embedder like
# "openai/text-embedding-3-small" (needs that provider's key above).
