{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "@vibe/protocol": [
        "../../../packages/protocol/src/index.ts"
      ],
      "@shared/*": [
        "../src/shared/*"
      ],
      "@hooks/*": [
        "../src/renderer/hooks/*"
      ],
      "@relay/*": [
        "../relay/*"
      ]
    }
  },
  "include": [
    "src",
    "index.ts",
    "../src/shared"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "../src/shared/**/*.test.ts",
    "../src/renderer/**/*.test.ts"
  ]
}
