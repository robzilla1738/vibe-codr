{
  "name": "vibe-codr-desktop",
  "version": "0.6.11",
  "private": true,
  "author": "robzilla1738",
  "license": "MIT",
  "description": "Vibe Codr desktop — a local-first AI coding workspace powered by the shared Vibe Codr engine",
  "homepage": "https://www.vibe-codr.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robzilla1738/vibe-codr.git",
    "directory": "apps/desktop"
  },
  "bugs": {
    "url": "https://github.com/robzilla1738/vibe-codr/issues"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:icon": "node scripts/build-icon.mjs",
    "postinstall": "install-electron --no && electron-builder install-app-deps",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p relay/tsconfig.json",
    "lint": "biome lint --error-on-warnings .",
    "verify": "npm run lint && npm test && npm run verify:source-parity && npm run verify:config-shape && npm run typecheck && npm run build && npm run verify:bundle",
    "verify:fast": "npm run lint && npm test && npm run typecheck",
    "verify:ci": "npm run verify && npm run test:coverage && npm run smoke:bridge && npm run test:e2e",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:cloud:live": "VIBE_LIVE_CLOUD=1 vitest run src/main/cloud/providers.live.test.ts --no-file-parallelism",
    "test:watch": "vitest",
    "bench:performance": "VIBE_PERF_BENCH=1 vitest run src/main/performance.bench.test.ts --reporter=verbose",
    "verify:source-parity": "node scripts/check-source-parity.mjs",
    "verify:config-shape": "node scripts/check-config-shape.mjs",
    "verify:bundle": "node scripts/check-bundle-size.mjs",
    "ui:preview": "vite --config tools/ui-preview/vite.config.ts",
    "ui:shots": "node tools/ui-preview/shoot.mjs",
    "pack": "npm run pack:mac",
    "pack:mac": "npm run copy-host && npm run copy-runtime && npm run build && electron-builder --mac --dir --config.mac.identity=null --config.mac.hardenedRuntime=false --config.forceCodeSigning=false",
    "pack:win": "npm run copy-host && npm run copy-runtime && npm run build && electron-builder --win --dir --x64 --config.win.signAndEditExecutable=false --config.forceCodeSigning=false",
    "dist": "npm run dist:mac",
    "dist:mac": "npm run copy-host && npm run copy-runtime && npm run build && electron-builder --mac --arm64 --publish never",
    "dist:win": "npm run copy-host && npm run copy-runtime && npm run build && electron-builder --win nsis --x64 --publish never",
    "copy-host": "node scripts/copy-engine-host.mjs",
    "copy-runtime": "node scripts/copy-cloud-runtime.mjs",
    "smoke:bridge": "node scripts/smoke-bridge.mjs",
    "smoke:packaged": "node scripts/smoke-packaged.mjs",
    "smoke:packaged:relay": "node scripts/smoke-packaged-relay.mjs",
    "smoke:cloud:packaged": "node scripts/smoke-cloud-packaged.mjs",
    "providers:sync": "node scripts/sync-provider-manifest.mjs",
    "relay": "npm --prefix relay start --"
  },
  "dependencies": {
    "@vercel/sandbox": "^2.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "e2b": "^2.33.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.24.0",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "streamdown": "^2.5.0",
    "ws": "^8.21.1"
  },
  "optionalDependencies": {
    "electron-liquid-glass": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^3.2.7",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "build": {
    "appId": "com.vibecodr.desktop",
    "productName": "Vibe Codr",
    "artifactName": "Vibe-Codr-${version}-${os}-${arch}.${ext}",
    "electronUpdaterCompatibility": ">=2.16",
    "afterPack": "./scripts/after-pack.mjs",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "win": {
      "icon": "assets/icon.png",
      "executableName": "Vibe Codr",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Vibe Codr"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "robzilla1738",
        "repo": "vibe-codr",
        "releaseType": "release"
      }
    ],
    "icon": "assets/icon.icns",
    "files": [
      "out/**/*",
      "package.json",
      "ENGINE_COMMIT"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "vibecodr-engine-host*"
        ]
      },
      {
        "from": "resources/cloud-runtime",
        "to": "cloud-runtime",
        "filter": [
          "*.tar.gz",
          "*.sha256"
        ]
      }
    ]
  }
}
