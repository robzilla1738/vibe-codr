{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "node"
    ],
    "baseUrl": "..",
    "paths": {
      "@vibe/protocol": [
        "../../packages/protocol/src/index.ts"
      ],
      "@shared/*": [
        "src/shared/*"
      ]
    }
  },
  "include": [
    "qrcode-terminal.d.ts",
    "server.ts",
    "../src/main/engine-bridge.ts",
    "../src/main/host-resolver.ts",
    "../src/shared/protocol.ts",
    "../src/shared/commands.ts",
    "../src/shared/events.ts",
    "../src/shared/runtime-guards.ts",
    "../src/shared/stdin-write-queue.ts",
    "protocol.ts",
    "mobile-upload.ts",
    "../src/main/terminal-manager.ts",
    "../src/shared/terminal.ts",
    "../src/shared/cwd-allowlist.ts",
    "../src/shared/path-safe.ts",
    "../../../packages/protocol/src/**/*.ts"
  ],
  "exclude": ["../../../packages/protocol/src/**/*.test.ts"]
}
