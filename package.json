{
  "name": "vibe-codr",
  "version": "0.6.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "description": "A local-first AI coding workspace for desktop and terminal, powered by one model-agnostic engine.",
  "keywords": [
    "cli",
    "coding-agent",
    "ai",
    "agent",
    "llm",
    "terminal",
    "tui",
    "desktop",
    "electron",
    "bun",
    "anthropic",
    "openai",
    "ollama",
    "mcp"
  ],
  "repository": { "type": "git", "url": "git+https://github.com/robzilla1738/vibe-codr.git" },
  "homepage": "https://www.vibe-codr.com",
  "funding": "https://buymeacoffee.com/robcourson",
  "workspaces": ["packages/*"],
  "bin": {
    "vibecodr": "packages/cli/bin/vibecodr.ts",
    "vibe": "packages/cli/bin/vibecodr.ts"
  },
  "scripts": {
    "vibecodr": "bun packages/cli/bin/vibecodr.ts",
    "build": "turbo run build",
    "build:all": "bun run build && npm --prefix apps/desktop run build",
    "build:binary": "bun build packages/cli/bin/vibecodr.ts --compile --outfile dist/vibecodr && bun build packages/cli/src/engine-worker-entry.ts --compile --outfile dist/vibecodr-engine-worker && bun scripts/release/build-app.ts dist/vibecodr-app.js",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "smoke:tui": "bun packages/tui/scripts/smoke.ts",
    "smoke:sidebar": "bun packages/tui/scripts/sidebar-smoke.ts",
    "inspect:tui": "bun packages/tui/scripts/inspect.ts",
    "macos-bridge": "bun packages/macos-bridge/bin/engine-host.ts",
    "build:macos-bridge": "bun build packages/macos-bridge/bin/engine-host.ts --compile --outfile dist/vibecodr-engine-host",
    "build:cloud-runtime": "node scripts/build-cloud-runtime.mjs",
    "smoke:cloud-runtime": "node scripts/smoke-cloud-runtime.mjs",
    "desktop:dev": "npm --prefix apps/desktop run dev",
    "desktop:test": "npm --prefix apps/desktop test",
    "desktop:verify": "npm --prefix apps/desktop run verify",
    "desktop:verify:ci": "npm --prefix apps/desktop run verify:ci",
    "desktop:shots": "npm --prefix apps/desktop run ui:shots",
    "verify": "bun run lint && bun run typecheck && bun test",
    "verify:all": "bun run verify && npm --prefix apps/desktop run verify:ci",
    "lint": "biome lint packages",
    "format": "biome format --write packages",
    "clean": "turbo run clean && rm -rf node_modules dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@ai-sdk/amazon-bedrock": "^5.0.23",
    "@ai-sdk/anthropic": "^4.0.15",
    "@ai-sdk/azure": "^4.0.16",
    "@ai-sdk/deepseek": "^3.0.11",
    "@ai-sdk/google-vertex": "^5.0.21",
    "@ai-sdk/openai": "^4.0.15",
    "@ai-sdk/openai-compatible": "^3.0.11",
    "@aws-sdk/credential-providers": "^3.1087.0",
    "@biomejs/biome": "^2.5.1",
    "@opentui/core": "^0.4.2",
    "@opentui/solid": "^0.4.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.0",
    "msw": "^2.14.6",
    "playwright": "^1.61.1",
    "solid-js": "^1.9.12",
    "turbo": "^2.10.0",
    "typescript": "^5.9.3",
    "web-tree-sitter": "0.25.10"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "patchedDependencies": {
    "@opentui/core@0.4.2": "patches/@opentui%2Fcore@0.4.2.patch"
  }
}
