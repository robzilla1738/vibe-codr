{
  "name": "vibe-codr",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "description": "A cutting-edge, model-agnostic CLI coding agent for the terminal.",
  "workspaces": ["packages/*"],
  "bin": {
    "vibecodr": "packages/cli/bin/vibecodr.ts",
    "vibe": "packages/cli/bin/vibecodr.ts"
  },
  "scripts": {
    "vibecodr": "bun packages/cli/bin/vibecodr.ts",
    "build": "turbo run build",
    "build:binary": "bun build packages/cli/bin/vibecodr.ts --compile --outfile dist/vibecodr",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "smoke:tui": "bun packages/tui/scripts/smoke.ts",
    "inspect:tui": "bun packages/tui/scripts/inspect.ts",
    "lint": "biome lint packages",
    "format": "biome format --write packages",
    "clean": "turbo run clean && rm -rf node_modules dist"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^2.0.83",
    "@ai-sdk/deepseek": "^1.0.44",
    "@ai-sdk/openai": "^2.0.109",
    "@ai-sdk/openai-compatible": "^1.0.41",
    "@biomejs/biome": "^2.5.1",
    "@opentui/core": "^0.4.2",
    "@opentui/solid": "^0.4.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.0",
    "msw": "^2.14.6",
    "playwright": "^1.61.1",
    "solid-js": "^1.9.13",
    "turbo": "^2.10.0",
    "typescript": "^5.9.3",
    "web-tree-sitter": "0.25.10"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
